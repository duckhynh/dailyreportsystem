@page
@{ ViewData["Title"] = "Thêm báo cáo"; }

<div class="panel" style="max-width: 800px; margin: 0 auto;">
    <div class="panel-heading">Ghi nhận công việc thực tập (Submit Daily Report)</div>
    <div class="panel-body">
        <div id="status-msg" style="display:none;"></div>
        
        <form id="report-form">
            <div class="form-group" style="padding: 15px; background: #f9f9f9; border: 1px solid #eee; border-radius: 4px;">
                <label style="color: #d9530f;">Mã Dự án tham gia (Project ID):</label>
                <input type="number" id="projectId" class="form-control" style="max-width: 200px;" placeholder="Ví dụ: 1" required>
                <span class="help-block" style="font-size: 13px; color: #555;">(Dự án này bạn được phân công vào mã dự án = 1 trên CSDL)</span>
            </div>
            
            <div class="form-group">
                <label>Công việc đã hoàn thành (Tasks Done):</label>
                <textarea id="tasksDone" class="form-control" rows="4" required></textarea>
            </div>
            
            <div class="form-group">
                <label>Khó khăn/Vướng mắc (Issues):</label>
                <textarea id="issues" class="form-control" rows="2"></textarea>
            </div>
            
            <div class="form-group">
                <label>Kế hoạch ngày mai (Tomorrow's Plan):</label>
                <textarea id="tomorrowPlan" class="form-control" rows="3" required></textarea>
            </div>
            
            <hr style="margin: 20px 0;">
            <button type="submit" class="btn btn-primary" style="min-width: 100px;">Save changes</button>
            <a href="/" class="btn btn-default" style="margin-left: 10px;">Return</a>
        </form>
    </div>
</div>

<script>
if(!localStorage.getItem('token')) {
    window.location.href = '/Login';
}

document.getElementById('report-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = localStorage.getItem('token');
    const msgBox = document.getElementById('status-msg');
    const btn = e.target.querySelector('button');
    
    btn.disabled = true;
    btn.textContent = "Processing...";
    msgBox.style.display = 'none';
    
    try {
        const payload = {
            userId: parseInt(localStorage.getItem('userId')),
            projectId: parseInt(document.getElementById('projectId').value),
            tasksDone: document.getElementById('tasksDone').value,
            issues: document.getElementById('issues').value,
            tomorrowPlan: document.getElementById('tomorrowPlan').value
        };

        const res = await fetch('/api/Report', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json', 
                'Authorization': `Bearer ${token}` 
            },
            body: JSON.stringify(payload)
        });
        
        const data = await res.json();
        
        if (res.ok) {
            msgBox.className = 'alert alert-success';
            msgBox.innerHTML = `<strong>Thành công!</strong> Đã thêm biên lai lưu trữ vào DB. Mã Record ID: ${data.id}`;
            msgBox.style.display = 'block';
            document.getElementById('report-form').reset();
            window.scrollTo(0,0);
        } else {
            msgBox.className = 'alert alert-danger';
            msgBox.innerHTML = `<strong>Thất bại!</strong> Chấm dứt thao tác do vi phạm Business Logic: ${data.message || data.error || "Dữ liệu sai."}`;
            msgBox.style.display = 'block';
            window.scrollTo(0,0);
        }
    } catch(err) {
        msgBox.className = 'alert alert-danger';
        msgBox.innerHTML = `<strong>Lỗi kết nối Socket TCP!</strong> C# Server không phản hồi.`;
        msgBox.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = "Save changes";
    }
});
</script>
