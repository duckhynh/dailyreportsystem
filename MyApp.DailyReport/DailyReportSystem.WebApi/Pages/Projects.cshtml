@page
@{ ViewData["Title"] = "Quản lý Dự án"; }

<div class="panel" style="max-width: 900px; margin: 0 auto;">
    <div class="panel-heading">Quản lý Dự án (Projects)</div>
    <div class="panel-body">
        <div style="margin-bottom: 20px;" id="manager-actions">
            <!-- Chỉ hiện cho Manager/Admin -->
        </div>

        <table class="table" style="width: 100%; text-align: left;">
            <thead>
                <tr>
                    <th style="border-bottom: 2px solid #ddd;">ID</th>
                    <th style="border-bottom: 2px solid #ddd;">Tên Dự án</th>
                    <th style="border-bottom: 2px solid #ddd;">Mô tả</th>
                    <th style="border-bottom: 2px solid #ddd;">Hành động</th>
                </tr>
            </thead>
            <tbody id="projects-tbody">
                <tr><td colspan="4">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<script>
    const token = localStorage.getItem('token');
    if (!token) window.location.href = '/Login';

    let role = "";
    try {
        const payload = JSON.parse(atob(token.split('.')[1]));
        role = payload['http://schemas.microsoft.com/ws/2008/06/identity/claims/role'] || payload.role;
    } catch(e) {}

    if (role === "Manager") {
        document.getElementById('manager-actions').innerHTML = `<button class="btn btn-primary" onclick="window.location.href='/ProjectForm'">Tạo mới Dự án</button>`;
    }

    async function loadProjects() {
        try {
            const res = await fetch('/api/Project', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                const data = await res.json();
                const tbody = document.getElementById('projects-tbody');
                tbody.innerHTML = '';
                if(data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4">Không có dữ liệu.</td></tr>';
                    return;
                }
                data.forEach(p => {
                    const row = document.createElement('tr');
                    
                    let actions = `<button class="btn btn-default btn-sm" onclick="window.location.href='/Tasks?projectId=${p.id}'">Xem Tasks</button> `;
                    if (role === 'Manager') {
                        actions += `<button class="btn btn-info btn-sm" onclick="window.location.href='/ProjectForm?id=${p.id}'">Sửa</button> `;
                        actions += `<button class="btn btn-danger btn-sm" onclick="deleteProject(${p.id})">Xoá</button>`;
                    }

                    row.innerHTML = `
                        <td style="border-bottom: 1px solid #eee;">${p.id}</td>
                        <td style="border-bottom: 1px solid #eee;"><b>${p.projectName}</b></td>
                        <td style="border-bottom: 1px solid #eee;">${p.description}</td>
                        <td style="border-bottom: 1px solid #eee;">${actions}</td>
                    `;
                    tbody.appendChild(row);
                });
            }
        } catch(e) {}
    }

    async function deleteProject(id) {
        if(!confirm('Xoá dự án này sẽ xoá toàn bộ Tasks và Reports liên quan. Tiếp tục?')) return;
        const res = await fetch(`/api/Project/${id}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) { alert('Xoá thành công!'); loadProjects(); }
        else { alert('Lỗi khi xoá!'); }
    }

    document.addEventListener('DOMContentLoaded', loadProjects);
</script>
