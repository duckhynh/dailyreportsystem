@page
@{ ViewData["Title"] = "Lịch sử báo cáo"; }

<div class="panel">
    <div class="panel-heading" style="display:flex; justify-content: space-between; align-items: center;">
        Tra cứu danh sách chuyên cần (Report History)
    </div>
    <div class="panel-body">
        
        <div id="loading" style="padding: 10px; color: #8a6d3b;"><i>Hệ thống API đang tải danh sách của bạn...</i></div>
        
        <div class="table-responsive" style="margin-top: 10px;">
            <table id="reportTable" class="table table-bordered table-striped table-hover" style="display:none;">
                <thead>
                    <tr>
                        <th style="width: 5%; text-align: center;">Mã (#)</th>
                        <th style="width: 10%; text-align: center;">Dự Án</th>
                        <th style="width: 40%;">Chi tiết Công việc</th>
                        <th style="width: 25%;">Vấn đề tồn đọng</th>
                        <th style="width: 20%; text-align: center;">Ngày nộp (Timestamp)</th>
                    </tr>
                </thead>
                <tbody id="reportTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
if(!localStorage.getItem('token')) {
    window.location.href = '/Login';
}

async function loadReports() {
    const table = document.getElementById('reportTable');
    const tbody = document.getElementById('reportTableBody');
    const loading = document.getElementById('loading');
    
    try {
        const res = await fetch(`/api/Report/user/${localStorage.getItem('userId')}`, {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
        });
        
        if (res.ok) {
            const reports = await res.json();
            loading.style.display = 'none';
            table.style.display = 'table';
            
            if(reports.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding: 30px;"><em>Sinh viên hiện tại chưa nộp báo cáo chuyên cần nào.</em></td></tr>`;
                return;
            }
            
            reports.forEach(r => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="text-align:center;"><b>${r.id}</b></td>
                    <td style="text-align:center;">
                        <span class="label" style="background:#5bc0de; color:white; padding: 2px 6px; border-radius: 3px; font-size: 12px;">PRJ-${r.projectId}</span>
                    </td>
                    <td style="word-break: break-word;">${r.tasksDone}</td>
                    <td style="word-break: break-word; color:#737373;">${r.issues || '-'}</td>
                    <td style="text-align:center; color:#777;">${new Date(r.createdAt).toLocaleString()}</td>
                `;
                tbody.appendChild(tr);
            });
        } else {
            loading.innerHTML = "<span style='color:#a94442;'>Lỗi phân quyền mạng ngầm (401 Unauthorized API).</span>";
        }
    } catch(err) {
        loading.innerHTML = "<span style='color:#a94442;'>Chức năng tạm ngừng hoạt động do lỗi SQL Database.</span>";
    }
}

document.addEventListener('DOMContentLoaded', loadReports);
</script>
