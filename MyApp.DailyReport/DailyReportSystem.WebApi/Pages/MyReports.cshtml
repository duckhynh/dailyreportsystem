@page
@{
    ViewData["Title"] = "Quản lý Báo Cáo";
}

<div class="mb-4">
    <h1 style="font-size: 1.5rem; font-weight: 600;">Lịch sử Báo Cáo</h1>
    <p style="color: var(--text-muted); font-size: 0.875rem;">Thông kê danh sách báo cáo bạn đã gửi lên cơ sở dữ liệu.</p>
</div>

<div class="enterprise-card" style="padding: 0; overflow-x: auto;">
    <div id="loading" style="padding: 2rem; text-align: center; color: var(--text-muted);">Đang truy xuất hệ thống...</div>

    <table id="reportTable" class="minimal-table" style="display:none;">
        <thead>
            <tr>
                <th>Mã BC</th>
                <th>Dự án</th>
                <th>Công việc</th>
                <th>Vấn đề</th>
                <th>Ngày tạo</th>
            </tr>
        </thead>
        <tbody id="reportTableBody">
            <!-- Render ngầm Javascript -->
        </tbody>
    </table>
</div>

<script>
if(!localStorage.getItem('token')) {
    window.location.href = '/Login';
}

async function loadReports() {
    const token = localStorage.getItem('token');
    const userId = localStorage.getItem('userId');
    const tbody = document.getElementById('reportTableBody');
    const table = document.getElementById('reportTable');
    const loading = document.getElementById('loading');

    try {
        const res = await fetch(`/api/Report/user/${userId}`, {
            headers: {
                'Authorization': `Bearer ${token}`
            }
        });

        if (res.ok) {
            const reports = await res.json();
            loading.style.display = 'none';
            table.style.display = 'table';
            
            if(reports.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding:2rem; color:var(--text-muted);">Chưa có dữ liệu.</td></tr>`;
                return;
            }

            reports.forEach(r => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="font-weight: 500;">#${r.id}</td>
                    <td>PRJ-${r.projectId}</td>
                    <td><div style="max-width:250px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${r.tasksDone}">${r.tasksDone}</div></td>
                    <td><div style="max-width:150px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${r.issues || '-'}</div></td>
                    <td style="color:var(--text-muted); font-size:0.75rem;">${new Date(r.createdAt).toLocaleString()}</td>
                `;
                tbody.appendChild(tr);
            });
        } else {
            loading.textContent = "Không có quyền truy cập.";
            loading.classList.add('alert-error');
        }
    } catch(err) {
        loading.textContent = "Lỗi kết nối mạng.";
        loading.classList.add('alert-error');
    }
}

document.addEventListener('DOMContentLoaded', loadReports);
</script>
