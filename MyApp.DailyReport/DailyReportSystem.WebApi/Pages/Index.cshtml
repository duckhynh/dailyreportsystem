@page
@model IndexModel
@{ ViewData["Title"] = "Trang chủ"; }

<h3 style="margin-top: 0; padding-bottom: 9px; margin-bottom: 20px; border-bottom: 1px solid #eee; color: #f36f21; font-weight: normal;">
    Cổng thông tin Daily Report ERP
</h3>

<div style="display:flex; flex-wrap: wrap; margin-left: -15px; margin-right: -15px;">
    <!-- Project Panel -->
    <div style="padding-left: 15px; padding-right: 15px; width: 50%; box-sizing: border-box;">
        <div class="panel" style="border-color: #bce8f1;">
            <div class="panel-heading" style="color: #31708f; background-color: #d9edf7; border-color: #bce8f1;">
                Thống kê Hệ thống môn học (SWD392)
            </div>
            <div class="panel-body">
                <h2 style="margin-top: 0; color: #337ab7;"><b>@Model.ProjectCount</b> Dự án</h2>
                <p>EF Core kết nối thành công tới SQL Server Localhost.</p>
                <br>
                <a href="/SubmitReport" class="btn btn-primary btn-sm">Bắt đầu phiên báo cáo »</a>
            </div>
        </div>
    </div>
    
    <!-- Info Panel -->
    <div style="padding-left: 15px; padding-right: 15px; width: 50%; box-sizing: border-box;">
        <div class="panel" style="border-color: #faebcc;">
            <div class="panel-heading" style="color: #8a6d3b; background-color: #fcf8e3; border-color: #faebcc;">
                Tích hợp API Backend C# (Swagger)
            </div>
            <div class="panel-body">
                <p style="margin-bottom: 20px;">Toàn bộ API Backend đã được bảo mật bằng chuẩn JWT (JSON Web Token). Cổng tài liệu Swagger đã bật.</p>
                <a href="/swagger" target="_blank" class="btn btn-warning btn-sm" style="background-color: #f36f21; border-color: #d9530f;">Mở Cổng API Docs »</a>
            </div>
        </div>
    </div>
</div>
