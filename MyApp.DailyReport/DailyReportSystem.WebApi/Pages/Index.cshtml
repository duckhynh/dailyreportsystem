@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header mb-8">
    <h1 class="page-title">Trang Quản Trị Hệ Thống</h1>
    <p class="page-desc">Giao diện Đẳng cấp Doanh nghiệp (Premium Minimalist) gắn liền Web API.</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
    <div class="enterprise-card" style="padding: 2rem;">
        <label style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Tổng số Dự Án Mở</label>
        <div style="font-size: 2.5rem; font-weight: 700; color: var(--text-main); line-height: 1;">@Model.ProjectCount</div>
        <div style="margin-top: 1rem; color: #10b981; font-weight: 500; font-size: 0.875rem; display: flex; align-items: center; gap: 0.375rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
            Tăng trưởng
        </div>
    </div>

    <div class="enterprise-card" style="padding: 2rem;">
        <label style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Trạng thái Máy Chủ</label>
        <div style="font-size: 1.25rem; font-weight: 600; color: #0f172a; margin-top: 0.5rem; display: flex; align-items: center; gap: 0.75rem;">
            <span style="display: flex; position: relative;">
                <span style="position: absolute; display: inline-flex; height: 100%; width: 100%; border-radius: 50%; background-color: #22c55e; opacity: 0.4; animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
                <span style="position: relative; display: inline-flex; border-radius: 50%; height: 12px; width: 12px; background-color: #16a34a;"></span>
            </span>    
            Backend Running
        </div>
        <p style="margin-top: 1rem; color: #64748b; font-size: 0.875rem;">Bảo mật qua C# JWT</p>
    </div>

    <div class="enterprise-card" style="padding: 2rem;">
        <label style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Lối Tắt Lập Trình Viên</label>
        <div style="margin-top: 1.5rem;">
            <a href="/swagger" class="btn btn-outline w-full" style="display: flex; gap: 0.5rem; border-color: #cbd5e1;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Xem Swagger UI
            </a>
        </div>
    </div>
</div>

<style>
@@keyframes ping {
  75%, 100% {
    transform: scale(2);
    opacity: 0;
  }
}
</style>
