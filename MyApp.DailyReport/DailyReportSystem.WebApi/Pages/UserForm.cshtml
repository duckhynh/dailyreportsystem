@page
@{ ViewData["Title"] = "Thêm/Sửa Người Dùng"; }

<div class="panel" style="max-width: 600px; margin: 0 auto;">
    <div class="panel-heading" id="form-title">Thêm/Sửa Người dùng</div>
    <div class="panel-body">
        <div id="status-msg" style="display:none;"></div>
        
        <form id="user-form">
            <div class="form-group">
                <label>Tên đăng nhập (Username):</label>
                <input type="text" id="username" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label>Mật khẩu (Password):</label>
                <input type="text" id="password" class="form-control" placeholder="Để trống nếu không muốn đổi mật khẩu (đối với Edit)">
            </div>
            
            <div class="form-group">
                <label>Họ và Tên (Full Name):</label>
                <input type="text" id="fullName" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="email" class="form-control" placeholder="example@domain.com">
            </div>

            <div class="form-group">
                <label>Vai trò (Role):</label>
                <select id="role" class="form-control" required>
                    <option value="1">Admin</option>
                    <option value="2">Manager</option>
                    <option value="3">Employee</option>
                </select>
            </div>
            
            <hr style="margin: 20px 0;">
            <button type="submit" class="btn btn-primary" style="min-width: 100px;">Save changes</button>
            <a href="/Users" class="btn btn-default" style="margin-left: 10px;">Return</a>
        </form>
    </div>
</div>

<script>
    const token = localStorage.getItem('token');
    if (!token) window.location.href = '/Login';

    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('id');

    document.addEventListener('DOMContentLoaded', async () => {
        if (editId) {
            document.getElementById('form-title').innerText = "Chỉnh sửa Người dùng #" + editId;
            document.getElementById('username').disabled = true; // Không cho sửa username
            
            try {
                const res = await fetch(`/api/User/${editId}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (res.ok) {
                    const data = await res.json();
                    document.getElementById('username').value = data.username;
                    document.getElementById('fullName').value = data.fullName;
                    document.getElementById('email').value = data.email;
                    document.getElementById('role').value = data.role;
                }
            } catch(e) { console.error(e); }
        } else {
            document.getElementById('form-title').innerText = "Tạo mới Người dùng";
            document.getElementById('password').required = true;
        }
    });

    document.getElementById('user-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const msgBox = document.getElementById('status-msg');
        const btn = e.target.querySelector('button');
        
        btn.disabled = true;
        btn.textContent = "Processing...";
        msgBox.style.display = 'none';
        
        const payload = {
            fullName: document.getElementById('fullName').value,
            email: document.getElementById('email').value,
            role: parseInt(document.getElementById('role').value)
        };
        const pass = document.getElementById('password').value;

        let url = '/api/User';
        let method = 'POST';

        if (editId) {
            url = `/api/User/${editId}`;
            method = 'PUT';
            if (pass) payload.password = pass; // password opt for PUT
            // Note: username is not sent in PUT
        } else {
            method = 'POST';
            payload.username = document.getElementById('username').value;
            payload.password = pass; // mandatory
        }
        
        try {
            const res = await fetch(url, {
                method: method,
                headers: { 
                    'Content-Type': 'application/json', 
                    'Authorization': `Bearer ${token}` 
                },
                body: JSON.stringify(payload)
            });
            
            if (res.ok) {
                msgBox.className = 'alert alert-success';
                msgBox.innerHTML = `<strong>Thành công!</strong> Dữ liệu đã được lưu.`;
                msgBox.style.display = 'block';
                if (!editId) {
                    document.getElementById('user-form').reset();
                } else {
                    document.getElementById('password').value = '';
                }
            } else {
                msgBox.className = 'alert alert-danger';
                msgBox.innerHTML = `<strong>Thất bại!</strong> Dữ liệu không hợp lệ.`;
                msgBox.style.display = 'block';
            }
        } catch(err) {
            msgBox.className = 'alert alert-danger';
            msgBox.innerHTML = `<strong>Lỗi kết nối!</strong> Server không phản hồi.`;
            msgBox.style.display = 'block';
        } finally {
            btn.disabled = false;
            btn.textContent = "Save changes";
        }
    });
</script>
